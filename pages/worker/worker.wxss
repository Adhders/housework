/* pages/worker/worker.wxss */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.filter-btn {
  width: 100rpx;
  height: 72rpx;
  background: white;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.quick-filters {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  margin-bottom: 20rpx;
  padding-bottom: 8rpx;
}

.quick-filters::-webkit-scrollbar {
  display: none;
}

.filter-chip {
  padding: 12rpx 32rpx;
  background: white;
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.filter-chip.active {
  background: #4CAF50;
  color: white;
  font-weight: bold;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.order-card:active {
  transform: scale(0.98);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-left {
  flex: 1;
  margin-right: 20rpx;
}

.order-type {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-right {
  text-align: right;
}

.order-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #f44336;
  margin-bottom: 8rpx;
}

.order-duration {
  font-size: 24rpx;
  color: #999;
}

.order-body {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-info {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #666;
}

.order-info .icon {
  margin-right: 12rpx;
  font-size: 26rpx;
  margin-top: 2rpx;
}

.order-info .text {
  flex: 1;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.order-footer {
  padding: 20rpx 0 0 0;
  border-top: 1rpx solid #f0f0f0;
}

.grab-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.grab-btn::after {
  border: none;
}

.grab-btn:active {
  transform: scale(0.98);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.filter-content {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.price-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.price-item {
  width: calc(50% - 8rpx);
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.price-item.active {
  background: #4CAF50;
  color: white;
  font-weight: bold;
}
