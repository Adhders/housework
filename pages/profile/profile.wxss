/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 0 0 40rpx 40rpx;
  padding: 60rpx 40rpx 80rpx;
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.2);
  position: relative;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 500;
  color: white;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 28rpx;
  opacity: 0.9;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.edit-btn {
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 255, 255, 0.2);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s;
}

.edit-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.edit-icon {
  font-size: 32rpx;
}

/* 统计卡片区域 */
.stats-section {
  background: white;
  margin: -40rpx 40rpx 30rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  transition: transform 0.2s;
}

.stat-card:active {
  transform: scale(0.95);
}

.stat-total {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stat-pending {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.stat-accepted {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.stat-completed {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stats-amount {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 16rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: 500;
}

.amount-value {
  font-size: 40rpx;
  color: #FF6B00;
  font-weight: 700;
}

/* 功能菜单 */
.menu-section {
  background: white;
  margin: 40rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 32rpx;
  width: 80rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 16rpx;
}

/* 退出登录按钮 */
.logout-section {
  margin: 40rpx;
}

.logout-btn {
  background: white;
  color: #ff4444;
  border: 1rpx solid #ffcccc;
  border-radius: 12rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.logout-btn:active {
  background: #fff5f5;
  transform: scale(0.98);
}