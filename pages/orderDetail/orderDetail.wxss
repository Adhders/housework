/* pages/orderDetail/orderDetail.wxss */
.status-card {
  text-align: center;
  padding: 60rpx 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: white;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.info-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.price {
  color: #f44336;
  font-size: 32rpx;
  font-weight: bold;
}

.call-link {
  color: #4CAF50;
  margin-left: 20rpx;
  font-size: 26rpx;
}

.call-icon {
  color: #f44336;
  margin-left: 20rpx;
  font-size: 32rpx;
}

.requirements-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.grab-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.cancel-btn {
  background: #f44336;
  color: white;
}

.complete-btn {
  background: #2196F3;
  color: white;
}

.edit-btn {
  background: #4CAF50;
  color: white;
}

.save-btn {
  background: #4CAF50;
  color: white;
}

.cancel-edit-btn {
  background: #999;
  color: white;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 300rpx;
  height: 80rpx;
  background: #4CAF50;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.back-btn::after {
  border: none;
}

/* 编辑模式样式 */
.edit-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.edit-item:last-child {
  border-bottom: none;
}

.edit-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.edit-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.edit-textarea {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

/* 服务图片样式 */
.image-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: normal;
}

.service-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: calc(33.33% - 11rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.service-img {
  width: 100%;
  height: 100%;
}

.no-images {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.no-images-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.no-images-text {
  font-size: 26rpx;
  color: #999;
}

.upload-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
}

.upload-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #666;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
}

/* 地图导航样式 */
.address-text {
  flex: 1;
  text-align: right;
  word-break: break-all;
  padding-left: 20rpx;
}

.map-container {
  margin-top: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.location-map {
  width: 100%;
  height: 360rpx;
  display: block;
}

.map-nav-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(33, 150, 243, 0.9);
  padding: 16rpx 0;
  gap: 8rpx;
}

.map-nav-tip .nav-icon {
  font-size: 30rpx;
}

.map-nav-tip .nav-text {
  font-size: 26rpx;
  color: #fff;
}

.nav-btn-wrap {
  margin-top: 24rpx;
}

.nav-text-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 0;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
}

.nav-text-btn .nav-icon {
  font-size: 32rpx;
}

/* 静态地图样式 */
.static-map {
  width: 100%;
  height: 360rpx;
  position: relative;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.map-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.grid-line {
  position: absolute;
  background: rgba(76, 175, 80, 0.15);
}

.grid-line.horizontal {
  width: 100%;
  height: 2rpx;
  left: 0;
}

.grid-line.horizontal:nth-child(1) { top: 25%; }
.grid-line.horizontal:nth-child(2) { top: 50%; }
.grid-line.horizontal:nth-child(3) { top: 75%; }

.grid-line.vertical {
  width: 2rpx;
  height: 100%;
  top: 0;
}

.grid-line.vertical:nth-child(4) { left: 25%; }
.grid-line.vertical:nth-child(5) { left: 50%; }
.grid-line.vertical:nth-child(6) { left: 75%; }

.map-pin {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  z-index: 1;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2));
}

.map-address {
  font-size: 28rpx;
  color: #333;
  padding: 0 40rpx;
  text-align: center;
  z-index: 1;
  background: rgba(255, 255, 255, 0.9);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  max-width: 80%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 导航按钮 */
.nav-btn-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  background: #f44336;
  margin-top: 4rpx;
}

.nav-btn-icon {
  font-size: 32rpx;
}

.nav-btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
