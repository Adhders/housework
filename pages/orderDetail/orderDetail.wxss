/* pages/orderDetail/orderDetail.wxss */
.status-card {
  text-align: center;
  padding: 60rpx 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: white;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.info-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.price {
  color: #f44336;
  font-size: 32rpx;
  font-weight: bold;
}

.call-link {
  color: #4CAF50;
  margin-left: 20rpx;
  font-size: 26rpx;
}

.requirements-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.grab-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.cancel-btn {
  background: #f44336;
  color: white;
}

.complete-btn {
  background: #2196F3;
  color: white;
}

.edit-btn {
  background: #FF9800;
  color: white;
}

.save-btn {
  background: #4CAF50;
  color: white;
}

.cancel-edit-btn {
  background: #999;
  color: white;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 300rpx;
  height: 80rpx;
  background: #4CAF50;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.back-btn::after {
  border: none;
}

/* 编辑模式样式 */
.edit-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.edit-item:last-child {
  border-bottom: none;
}

.edit-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.edit-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.edit-textarea {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}
