<!-- pages/orderDetail/orderDetail.wxml -->
<view class="container" wx:if="{{order}}">
  <!-- 订单状态卡片 -->
  <view class="status-card" style="background: {{statusBgColor[order.status]}}">
    <view class="status-icon">{{statusIcon[order.status]}}</view>
    <view class="status-text">{{statusText[order.status]}}</view>
    <view class="status-desc">{{statusDesc[order.status]}}</view>
  </view>

  <!-- 订单信息 -->
  <view class="info-section">
    <view class="section-title">订单信息</view>
    
      <view class="info-item">
        <view class="info-label">服务类型</view>
        <view class="info-value">{{order.serviceTypeName}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">服务价格</view>
        <view class="info-value price">¥{{order.price}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">服务时长</view>
        <view class="info-value">{{order.duration}}小时</view>
      </view>

      <view class="info-item">
        <view class="info-label">服务时间</view>
        <view class="info-value">{{order.serviceTime}}</view>
      </view>
  </view>

  <!-- 地址信息 -->
  <view class="info-section">
    <view class="section-title">地址信息</view>
    
      <view class="info-item">
        <view class="info-label">服务地址</view>
        <view class="info-value address-text">{{order.address}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">详细地址</view>
        <view class="info-value address-text">{{order.city}} {{order.detailAddress}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">联系人</view>
        <view class="info-value">{{order.contactName}}</view>
      </view>

      <view class="info-item" style="border-bottom: none;">
        <view class="info-label">联系电话</view>
        <view class="info-value">
          <text>{{hidePhone(order.contactPhone)}}</text>
          <text class="call-icon" bindtap="makeCall">📞</text>
        </view>
      </view>

      <!-- 地图区域 -->
      <view class="map-container" wx:if="{{order.latitude && order.longitude}}">
        <map
          class="location-map"
          latitude="{{order.latitude}}"
          longitude="{{order.longitude}}"
          scale="{{order.useCurrentLocation ? 14 : 15}}"
          show-location
          markers="{{mapMarkers}}"
          bindmarkertap="openNavigation"
          bindtap="openNavigation"
          enable-zoom
          enable-scroll
        ></map>
        <view class="nav-btn-bar" bindtap="openNavigation">
          <text class="nav-btn-icon">📍</text>
          <text class="nav-btn-text">导航到此处</text>
        </view>
      </view>
  </view>

  <!-- 人员信息 -->
  <view class="info-section">
    <view class="section-title">人员信息</view>
    
    <view class="info-item">
      <view class="info-label">派单人</view>
      <view class="info-value">{{order.dispatcherName}}</view>
    </view>

    <view class="info-item" wx:if="{{order.workerName}}">
      <view class="info-label">接单人</view>
      <view class="info-value">{{order.workerName}}</view>
    </view>

    <view class="info-item" wx:if="{{order.workerPhone}}">
      <view class="info-label">接单人电话</view>
      <view class="info-value">
        <text>{{hidePhone(order.workerPhone)}}</text>
        <text class="call-icon" bindtap="callWorker">📞</text>
      </view>
    </view>
  </view>

  <!-- 备注信息 -->
  <view class="info-section" wx:if="{{order.requirements}}">
    <view class="section-title">服务要求</view>
    <view class="requirements-text">{{order.requirements}}</view>
  </view>

  <!-- 服务图片（只在服务完成状态显示） -->
  <view class="info-section" wx:if="{{order.status === 'completed'}}">
    <view class="section-title">
      <text>服务图片</text>
      <text class="image-count" wx:if="{{order.serviceImages && order.serviceImages.length > 0}}">({{order.serviceImages.length}}张)</text>
    </view>
    
    <!-- 图片展示区域 -->
    <view class="service-images" wx:if="{{order.serviceImages && order.serviceImages.length > 0}}">
      <view 
        class="image-item" 
        wx:for="{{order.serviceImages}}" 
        wx:key="index"
        bindtap="previewImage"
        data-url="{{item}}"
        data-index="{{index}}"
      >
        <image src="{{item}}" mode="aspectFill" class="service-img"/>
      </view>
    </view>
    
    <!-- 无图片提示 -->
    <view class="no-images" wx:if="{{!order.serviceImages || order.serviceImages.length === 0}}">
      <text class="no-images-icon">📷</text>
      <text class="no-images-text">暂无服务图片</text>
    </view>
  </view>

  <!-- 编辑按钮（派单员可以编辑待接单订单） -->
  <view class="action-section" wx:if="{{canEdit}}">
    <button 
      class="action-btn edit-btn"
      bindtap="startEdit"
    >
      编辑订单
    </button>
  </view>

  <!-- 订单操作 -->
  <view class="action-section" wx:if="{{showActions}}">
    <button 
      class="action-btn grab-btn"
      wx:if="{{order.status === 'pending' && canGrab}}"
      bindtap="grabOrder"
    >
      立即抢单
    </button>

    <button 
      class="action-btn cancel-btn"
      wx:if="{{order.status === 'pending' && canCancel}}"
      bindtap="cancelOrder"
    >
      取消订单
    </button>

    <button 
      class="action-btn complete-btn"
      wx:if="{{order.status === 'accepted' && canComplete}}"
      bindtap="completeOrder"
    >
      完成订单
    </button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 错误状态 -->
<view class="error-container" wx:if="{{error}}">
  <text class="error-icon">😔</text>
  <text class="error-text">订单不存在</text>
  <button class="back-btn" bindtap="goBack">返回</button>
</view>
