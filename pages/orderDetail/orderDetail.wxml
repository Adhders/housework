<!-- pages/orderDetail/orderDetail.wxml -->
<view class="container" wx:if="{{order}}">
  <!-- 订单状态卡片 -->
  <view class="status-card" style="background: {{statusBgColor[order.status]}}">
    <view class="status-icon">{{statusIcon[order.status]}}</view>
    <view class="status-text">{{statusText[order.status]}}</view>
    <view class="status-desc">{{statusDesc[order.status]}}</view>
  </view>

  <!-- 订单信息 -->
  <view class="info-section">
    <view class="section-title">订单信息</view>
    
    <!-- 查看模式 -->
    <block wx:if="{{!isEditing}}">
      <view class="info-item">
        <view class="info-label">服务类型</view>
        <view class="info-value">{{order.serviceTypeName}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">服务价格</view>
        <view class="info-value price">¥{{order.price}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">服务时长</view>
        <view class="info-value">{{order.duration}}小时</view>
      </view>

      <view class="info-item">
        <view class="info-label">服务时间</view>
        <view class="info-value">{{order.serviceTime}}</view>
      </view>
    </block>
    
    <!-- 编辑模式 -->
    <block wx:if="{{isEditing}}">
      <view class="edit-item">
        <view class="edit-label">服务价格</view>
        <input class="edit-input" type="digit" value="{{editForm.price}}" data-field="price" bindinput="onEditInput" placeholder="请输入价格"/>
      </view>

      <view class="edit-item">
        <view class="edit-label">服务时长</view>
        <input class="edit-input" type="number" value="{{editForm.duration}}" data-field="duration" bindinput="onEditInput" placeholder="请输入时长"/>
      </view>

      <view class="edit-item">
        <view class="edit-label">服务日期</view>
        <input class="edit-input" value="{{editForm.serviceDate}}" data-field="serviceDate" bindinput="onEditInput" placeholder="请输入日期"/>
      </view>

      <view class="edit-item">
        <view class="edit-label">服务时间</view>
        <input class="edit-input" value="{{editForm.serviceTime}}" data-field="serviceTime" bindinput="onEditInput" placeholder="请输入时间"/>
      </view>
    </block>
  </view>

  <!-- 地址信息 -->
  <view class="info-section">
    <view class="section-title">地址信息</view>
    
    <!-- 查看模式 -->
    <block wx:if="{{!isEditing}}">
      <view class="info-item">
        <view class="info-label">服务地址</view>
        <view class="info-value">{{order.address}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">联系人</view>
        <view class="info-value">{{order.contactName}}</view>
      </view>

      <view class="info-item">
        <view class="info-label">联系电话</view>
        <view class="info-value">
          <text>{{hidePhone(order.contactPhone)}}</text>
          <text class="call-link" bindtap="makeCall">拨打</text>
        </view>
      </view>
    </block>
    
    <!-- 编辑模式 -->
    <block wx:if="{{isEditing}}">
      <view class="edit-item">
        <view class="edit-label">服务地址</view>
        <input class="edit-input" value="{{editForm.address}}" data-field="address" bindinput="onEditInput" placeholder="请输入地址"/>
      </view>

      <view class="edit-item">
        <view class="edit-label">联系人</view>
        <input class="edit-input" value="{{editForm.contactName}}" data-field="contactName" bindinput="onEditInput" placeholder="请输入联系人"/>
      </view>

      <view class="edit-item">
        <view class="edit-label">联系电话</view>
        <input class="edit-input" type="number" value="{{editForm.contactPhone}}" data-field="contactPhone" bindinput="onEditInput" placeholder="请输入联系电话"/>
      </view>
    </block>
  </view>

  <!-- 人员信息 -->
  <view class="info-section">
    <view class="section-title">人员信息</view>
    
    <view class="info-item">
      <view class="info-label">派单人</view>
      <view class="info-value">{{order.dispatcherName}}</view>
    </view>

    <view class="info-item" wx:if="{{order.workerName}}">
      <view class="info-label">接单人</view>
      <view class="info-value">{{order.workerName}}</view>
    </view>

    <view class="info-item" wx:if="{{order.workerPhone}}">
      <view class="info-label">接单人电话</view>
      <view class="info-value">
        <text>{{hidePhone(order.workerPhone)}}</text>
        <text class="call-link" bindtap="callWorker">拨打</text>
      </view>
    </view>
  </view>

  <!-- 备注信息 -->
  <view class="info-section" wx:if="{{!isEditing && order.requirements}}">
    <view class="section-title">服务要求</view>
    <view class="requirements-text">{{order.requirements}}</view>
  </view>
  
  <!-- 编辑模式下的服务要求 -->
  <view class="info-section" wx:if="{{isEditing}}">
    <view class="section-title">服务要求</view>
    <textarea class="edit-textarea" value="{{editForm.requirements}}" data-field="requirements" bindinput="onEditInput" placeholder="请输入服务要求"/>
  </view>

  <!-- 编辑按钮（派单员可以编辑待接单订单） -->
  <view class="action-section" wx:if="{{canEdit && !isEditing}}">
    <button 
      class="action-btn edit-btn"
      bindtap="startEdit"
    >
      编辑订单
    </button>
  </view>
  
  <!-- 编辑操作按钮 -->
  <view class="action-section" wx:if="{{isEditing}}">
    <button 
      class="action-btn save-btn"
      bindtap="saveEdit"
    >
      保存
    </button>
    <button 
      class="action-btn cancel-edit-btn"
      bindtap="cancelEdit"
    >
      取消
    </button>
  </view>

  <!-- 订单操作 -->
  <view class="action-section" wx:if="{{showActions && !isEditing}}">
    <button 
      class="action-btn grab-btn"
      wx:if="{{order.status === 'pending' && canGrab}}"
      bindtap="grabOrder"
    >
      立即抢单
    </button>

    <button 
      class="action-btn cancel-btn"
      wx:if="{{order.status === 'pending' && canCancel}}"
      bindtap="cancelOrder"
    >
      取消订单
    </button>

    <button 
      class="action-btn complete-btn"
      wx:if="{{order.status === 'accepted' && canComplete}}"
      bindtap="completeOrder"
    >
      完成订单
    </button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 错误状态 -->
<view class="error-container" wx:if="{{error}}">
  <text class="error-icon">😔</text>
  <text class="error-text">订单不存在</text>
  <button class="back-btn" bindtap="goBack">返回</button>
</view>
