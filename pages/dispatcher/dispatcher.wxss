/* pages/dispatcher/dispatcher.wxss */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s;
}

.action-btn.primary {
  background: #4CAF50;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.action-btn.secondary {
  background: white;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn .icon {
  font-size: 32rpx;
}

.recent-orders {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #4CAF50;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  transition: all 0.3s;
}

.order-card:active {
  transform: scale(0.98);
  background: #f0f0f0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.order-body {
  margin-bottom: 16rpx;
}

.order-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.order-info:last-child {
  margin-bottom: 0;
}

.info-icon {
  margin-right: 12rpx;
  font-size: 24rpx;
}

.info-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-text.price {
  color: #f44336;
  font-weight: bold;
  font-size: 28rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #e0e0e0;
  font-size: 22rpx;
  color: #999;
}

.order-worker {
  color: #4CAF50;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}
