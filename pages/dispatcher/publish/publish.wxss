/* pages/dispatcher/publish/publish.wxss */
.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label.required::before {
  content: '*';
  color: #f44336;
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: all 0.3s;
}

.form-input:focus {
  background: white;
  border: 2rpx solid #4CAF50;
}

.picker {
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s;
}

.picker.placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea:focus {
  background: white;
  border: 2rpx solid #4CAF50;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.time-picker-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.time-picker {
  flex: 1;
}

.time-divider {
  font-size: 28rpx;
  color: #999;
  padding: 0 10rpx;
}

.submit-section {
  padding: 40rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #4CAF50;
  color: white;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* Picker箭头样式 */
.picker-arrow {
  margin-left: auto;
  color: #999;
  font-size: 24rpx;
}

/* 地址输入框样式 */
.address-input-wrapper {
  position: relative;
  height: 88rpx;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding-right: 88rpx; /* Leave space for the map button */
}

.address-display {
  flex: 1;
  height: 100%;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.address-display.placeholder {
  color: #999;
}

.map-btn {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  width: 88rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.map-img {
  width: 56rpx;
  height: 56rpx;
}
