/* pages/dispatcher/stats/stats.wxss */
.container {
  padding: 20rpx 0;
  background: #f5f5f5;
  min-height: 100vh;
  overflow-y: auto;
}

/* 顶部统计卡片 */
.header-card {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  background: white;
  margin-bottom: 20rpx;
}

/* 日期范围选择器 */
.date-range-selector {
  background: white;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.range-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.range-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.range-btn {
  flex: 1;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: none;
  border-radius: 8rpx;
  text-align: center;
}

.range-btn.active {
  background: #4CAF50;
  color: white;
}

.date-info {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.card-item {
  flex: 0 0 calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #f5f5f5, #ffffff);
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.card-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.card-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.card-value.pending {
  color: #FF9800;
}

.card-value.accepted {
  color: #2196F3;
}

.card-value.completed {
  color: #4CAF50;
}

.card-value.cancelled {
  color: #999;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background: white;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #4CAF50;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 500;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 6rpx;
  background: #4CAF50;
  border-radius: 3rpx;
}

/* 内容区 */
.content {
  padding: 0 20rpx 20rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0 20rpx 10rpx;
}

/* 图表容器 */
.chart-container {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.chart-scroll {
  width: 100%;
  min-height: 300rpx;
}

.chart-bars {
  display: flex;
  gap: 12rpx;
  align-items: flex-end;
  min-width: 100%;
  padding: 20rpx 0;
  justify-content: space-around;
}

.bar-item {
  flex: 0 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 280rpx;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar-stack {
  display: flex;
  flex-direction: column;
  width: 40rpx;
  height: 240rpx;
  background: #f5f5f5;
  border-radius: 4rpx 4rpx 0 0;
  overflow: hidden;
}

.bar {
  width: 100%;
  transition: all 0.3s;
}

.bar.pending {
  background: #FF9800;
}

.bar.accepted {
  background: #2196F3;
}

.bar.completed {
  background: #4CAF50;
}

.bar.cancelled {
  background: #ccc;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
  white-space: nowrap;
}

.bar-total {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  margin-top: 8rpx;
}

/* 图例 */
.legend {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 10rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 3rpx;
}

.legend-color.pending {
  background: #FF9800;
}

.legend-color.accepted {
  background: #2196F3;
}

.legend-color.completed {
  background: #4CAF50;
}

.legend-color.cancelled {
  background: #ccc;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}

/* 统计表格 */
.stats-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.stats-header {
  display: flex;
  padding: 20rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  border-bottom: 1rpx solid #e0e0e0;
}

.stats-header text {
  flex: 1;
  text-align: center;
}

.stats-header text:first-child {
  text-align: left;
}

.stats-row {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #333;
  align-items: center;
}

.stats-row:last-child {
  border-bottom: none;
}

.stats-row text {
  flex: 1;
  text-align: center;
}

.stats-row .col-date {
  text-align: left;
  color: #666;
}

.stats-row .col-total {
  font-weight: bold;
}

.stats-row .col-pending {
  color: #FF9800;
}

.stats-row .col-accepted {
  color: #2196F3;
}

.stats-row .col-completed {
  color: #4CAF50;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.refresh-btn {
  background: #2196F3;
  color: white;
}

.export-btn {
  background: #4CAF50;
  color: white;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: #999;
}

.loading-text {
  font-size: 28rpx;
}
