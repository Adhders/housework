{
  "pages": [
    "pages/index/index",
    "pages/login/login",
    "pages/profile/profile",
    "pages/settings/settings",
    "pages/dispatcher/dispatcher",
    "pages/dispatcher/publish/publish",
    "pages/dispatcher/manage/manage",
    "pages/worker/worker",
    "pages/worker/myOrders/myOrders",
