  "permission": {
    "scope.userLocation": {
      "desc": "您的位置信息将用于订单服务区域"
    }
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "useExtendedLib": {
    "weui": true
  },
  "cloud": true,
  "lazyCodeLoading": "requiredComponents"
}
