/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background-color: #4CAF50;
  color: white;
  border: none;
}

.btn-secondary {
  background-color: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}

.btn-danger {
  background-color: #f44336;
  color: white;
  border: none;
}

.btn {
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin: 10rpx;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-primary {
  color: #4CAF50;
}

.text-danger {
  color: #f44336;
}

.text-warning {
  color: #ff9800;
}

.text-success {
  color: #4CAF50;
}

.text-muted {
  color: #999;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.p-20 {
  padding: 20rpx;
}
